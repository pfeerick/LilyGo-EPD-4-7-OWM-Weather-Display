# simulator/.env — credentials for the PC display simulator
#
# HOW TO USE:
#   1. Copy this file to simulator/.env  (it is gitignored)
#   2. Fill in your values below
#   3. Start the Bun preview server: bun run dev
#      The server loads this file automatically — no need to set env vars manually.
#
# The simulator calls the OWM One Call API 3.0, which requires a paid OWM subscription.
# Sign up at https://openweathermap.org/ and enable One Call API 3.0 in your account.

OWM_APIKEY=your_api_key_here
OWM_LAT=51.38
OWM_LON=-2.36
OWM_CITY=Bath

# M = Metric, I = Imperial (default: M)
OWM_UNITS=M

# Language code — same options as the firmware: EN AR CZ EL FA FR GL HU JA KR LA LT MK SK SL VI
OWM_LANG=EN

# UTC offset in seconds — must match the firmware's gmtOffset_sec setting
# Examples: 36000 (AEST+10), 0 (UTC), -18000 (EST-5), 3600 (CET+1)
OWM_GMT_OFFSET_SEC=0

# Daylight saving offset in seconds — must match firmware's daylightOffset_sec (usually 0 or 3600)
OWM_DST_OFFSET_SEC=0
